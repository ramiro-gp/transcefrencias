{
  "name": "transcefrencias",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint src vite.config.ts scripts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration:supabase": "node scripts/test-supabase-local.mjs",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:test:db": "supabase test db",
    "supabase:types": "supabase gen types typescript --local > src/lib/supabase/database.types.ts && prettier src/lib/supabase/database.types.ts --write",
    "benchmark:finance": "vitest bench --run src/domain/finance/optimize-transfers.bench.ts",
    "benchmark:finance:corpus": "node scripts/run-finance-corpus.mjs",
    "benchmark:finance:corpus:fresh": "node scripts/run-finance-corpus.mjs --fresh",
    "benchmark:finance:hybrid": "node scripts/run-finance-corpus.mjs --hybrid",
    "benchmark:finance:hybrid:fresh": "node scripts/run-finance-corpus.mjs --hybrid --fresh"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@supabase/supabase-js": "2.110.7",
    "@tanstack/react-query": "5.101.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "react-router": "7.18.1",
    "workbox-window": "7.4.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.10.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "fast-check": "4.9.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "supabase": "2.109.1",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10"
  }
}
